<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=794">
  <meta name="robots" content="noindex,nofollow,noarchive">
  <title>{{ report_title }} — 광교바른내과</title>
  <meta property="og:type" content="article">
  <meta property="og:url" content="{{ base_url }}/lab-reports/{{ topic }}/{{ slug }}/">
  <meta property="og:title" content="종합 건강검진 결과 안내 — 광교바른내과">
  <meta property="og:description" content="{{ og_description }}">
  <meta property="og:image" content="{{ base_url }}/shared/assets/clinic_logo.png">
  <meta property="og:site_name" content="광교바른내과">
  <meta name="theme-color" content="#003366">

  <link rel="stylesheet" as="style" crossorigin
    href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css" />

  <link rel="stylesheet" href="../../../shared/design-tokens.css">
  <link rel="stylesheet" href="../../../shared/clinic-handout-a4.css">
</head>
<body>

<div class="page">
  <header class="page__header">
    <img src="../../../shared/assets/clinic_logo.png" alt="광교바른내과" class="page__logo">
    <div class="page__eyebrow">LAB REPORT · <strong>HEALTH CHECKUP</strong> · 1 / {{ 2 if page2_needed else 1 }}</div>
  </header>

  <section class="page__title-block">
    <h1 class="page__title">{{ report_title }}</h1>
    <p class="page__subtitle">{{ patient_name }}{% if age_sex %} ({{ age_sex }}){% endif %} · 차트번호 {{ chart_no }} · 검사 {{ exam_date }} · 담당의 {{ doctor }} 원장{% if performed_tests %} · 검사항목 {{ performed_tests|length }}종{% endif %}</p>
  </section>

  <main class="page__body">
    <section>
      <h2 class="section-heading">종합 판정 (Overall Verdict)</h2>
      <div class="stats-row">
        {%- for s in overall[:4] %}
        <div class="stat-cell {{ stat_class(s.status) }}">
          <div class="stat-cell__label">{{ s.area or s.label }}</div>
          <div class="stat-cell__value">{{ s.value or ("정상" if s.status == "ok" else "주의") }}</div>
          <div class="stat-cell__unit">{{ s.summary or s.unit }}</div>
        </div>
        {%- endfor %}
      </div>
    </section>

    {%- if vitals %}
    <section>
      <h2 class="section-heading">신체계측·생체징후 (Vitals)</h2>
      <div class="stats-row">
        {%- for v in vitals[:4] %}
        <div class="stat-cell {{ stat_class(v.status) }}">
          <div class="stat-cell__label">{{ v.label }}</div>
          <div class="stat-cell__value">{{ v.value }}</div>
          <div class="stat-cell__unit">{{ v.unit }}</div>
        </div>
        {%- endfor %}
      </div>
    </section>
    {%- endif %}

    {%- if labs %}
    <section>
      <h2 class="section-heading">혈액검사 (Blood)</h2>
      <div class="card" style="padding:2mm 4mm;">
        <div class="lab-row lab-row--header">
          <div>항목</div>
          <div style="text-align:right;">결과</div>
          <div>참고치</div>
          <div></div>
        </div>
        {%- for row in labs[:8] %}
        <div class="lab-row">
          <div class="lab-row__label">{{ row.label }}</div>
          <div class="lab-row__value">{{ row.value }}</div>
          <div class="lab-row__range">{{ row.range }}</div>
          <div class="lab-row__badge {{ badge_class(row.status) }}">{{ row.badge or "정상" }}</div>
        </div>
        {%- endfor %}
      </div>
    </section>
    {%- endif %}

    {%- if urinalysis %}
    <section>
      <h2 class="section-heading">소변검사 (Urinalysis)</h2>
      <div class="card" style="padding:2mm 4mm;">
        {%- for row in urinalysis[:2] %}
        <div class="lab-row">
          <div class="lab-row__label">{{ row.label }}</div>
          <div class="lab-row__value">{{ row.value }}</div>
          <div class="lab-row__range">{{ row.range }}</div>
          <div class="lab-row__badge {{ badge_class(row.status) }}">{{ row.badge or "정상" }}</div>
        </div>
        {%- endfor %}
      </div>
    </section>
    {%- endif %}

    {%- if not page2_needed and action_plan %}
    <section>
      <h2 class="section-heading">권장 사항 · 다음 단계 (Action Plan)</h2>
      <div class="checklist">
        {%- for rec in action_plan[:5] %}
        <div class="checklist__item">
          <div class="checklist__num">{{ loop.index }}</div>
          <div class="checklist__text"><strong>{{ rec.title }}</strong> — {{ rec.text | safe }}</div>
        </div>
        {%- endfor %}
      </div>
    </section>
    {%- endif %}
  </main>

  <footer class="page__footer">
    <div class="page__footer-info">
      <div class="clinic-name">광교바른내과 · Gwanggyo Barun Internal Medicine</div>
      <div class="clinic-meta">경기 용인 수지구 광교중앙로 298, 4층 · ☏ 031-893-4560</div>
      <div class="clinic-meta">소화기내과 · 일반내과 · 5대암 검진</div>
      <div class="disclaimer">본 결과지는 환자 설명용 요약본입니다. 정확한 해석과 치료는 담당 의사 진료를 통해 결정합니다.</div>
    </div>
  </footer>
</div>

{%- if page2_needed %}
<div class="page">
  <header class="page__header">
    <img src="../../../shared/assets/clinic_logo.png" alt="광교바른내과" class="page__logo">
    <div class="page__eyebrow">LAB REPORT · <strong>HEALTH CHECKUP</strong> · 2 / 2</div>
  </header>

  <section class="page__title-block">
    <h1 class="page__title">영상·기능 검사 결과</h1>
    <p class="page__subtitle">{{ patient_name }}{% if age_sex %} ({{ age_sex }}){% endif %} · 차트번호 {{ chart_no }} · 검사 {{ exam_date }}</p>
  </section>

  <main class="page__body">
    {%- if endoscopy %}
    <section>
      <h2 class="section-heading">위·대장 내시경 (Endoscopy)</h2>
      <div class="body-2col">
        {%- for block in endoscopy[:2] %}
        <div class="card">
          <div class="card-label card-label--navy">{{ loop.index }}. {{ block.title }}</div>
          <ul class="card-list" style="font-size:8.5pt;">
            {%- for item in items(block.get("items"))[:4] %}
            <li>· {{ item | safe }}</li>
            {%- endfor %}
          </ul>
        </div>
        {%- endfor %}
      </div>
    </section>
    {%- endif %}

    {%- if ultrasound %}
    <section>
      <h2 class="section-heading">초음파 (Ultrasound)</h2>
      <div class="card" style="padding:3mm 4mm;">
        <ul class="card-list" style="font-size:8.7pt;">
          {%- for block in ultrasound[:4] %}
          <li>· <strong>{{ block.title }}</strong> — {{ items(block.get("items")) | join(" / ") | safe }}</li>
          {%- endfor %}
        </ul>
      </div>
    </section>
    {%- endif %}

    {%- if ekg or bmd %}
    <section>
      <div class="body-2col">
        {%- if ekg %}
        <div>
          <h2 class="section-heading">심전도 (EKG)</h2>
          <div class="card" style="padding:3mm 4mm;">
            <div class="card-label card-label--navy">{{ ekg.title }}</div>
            <ul class="card-list" style="font-size:8.5pt;">
              {%- for item in items(ekg.get("items"))[:3] %}
              <li>· {{ item | safe }}</li>
              {%- endfor %}
            </ul>
          </div>
        </div>
        {%- endif %}
        {%- if bmd %}
        <div>
          <h2 class="section-heading">골밀도 (DXA)</h2>
          <div class="stats-row" style="grid-template-columns:1fr 1fr; gap:2mm;">
            {%- for site in [bmd.get("lumbar"), bmd.get("femoral")] if site %}
            <div class="stat-cell {{ stat_class(site.status) }}">
              <div class="stat-cell__label">{{ site.label }}</div>
              <div class="stat-cell__value">{{ site.value }}</div>
              <div class="stat-cell__unit">{{ site.unit }}</div>
            </div>
            {%- endfor %}
          </div>
          <div style="font-size:8.3pt; color:var(--color-slate); margin-top:2mm; line-height:1.5;">
            {{ bmd.note }}
          </div>
        </div>
        {%- endif %}
      </div>
    </section>
    {%- endif %}

    {%- if action_plan %}
    <section>
      <h2 class="section-heading">권장 사항 · 다음 단계 (Action Plan)</h2>
      <div class="checklist">
        {%- for rec in action_plan[:5] %}
        <div class="checklist__item">
          <div class="checklist__num">{{ loop.index }}</div>
          <div class="checklist__text"><strong>{{ rec.title }}</strong> — {{ rec.text | safe }}</div>
        </div>
        {%- endfor %}
      </div>
    </section>
    {%- endif %}

    {%- if source_warnings %}
    <section>
      <h2 class="section-heading">확인 필요</h2>
      <div class="card card--warning" style="padding:2mm 4mm;">
        <ul class="card-list" style="font-size:8.2pt;">
          {%- for warning in source_warnings[:3] %}
          <li>· {{ warning }}</li>
          {%- endfor %}
        </ul>
      </div>
    </section>
    {%- endif %}
  </main>

  <footer class="page__footer">
    <div class="page__footer-info">
      <div class="clinic-name">광교바른내과 · Gwanggyo Barun Internal Medicine</div>
      <div class="clinic-meta">경기 용인 수지구 광교중앙로 298, 4층 · ☏ 031-893-4560</div>
      <div class="disclaimer">본 결과지는 환자 설명용 요약본입니다. 정확한 해석과 치료는 담당 의사 진료를 통해 결정합니다.</div>
    </div>
  </footer>
</div>
{%- endif %}

</body>
</html>
